# Token del bot de Telegram (@BotFather)
TELEGRAM_TOKEN=tu_token_aqui

# API Key de Google Gemini — FREE TIER, sin tarjeta de crédito
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ID de la hoja de Google Sheets
# URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEET_ID=tu_sheet_id_aqui

# Nombre de la pestaña (default: Registros)
GOOGLE_SHEET_NAME=Registros

# Credenciales de cuenta de servicio de Google (JSON en una sola línea)
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Tamaño del modelo Whisper local: tiny (rápido/liviano) o base (más preciso)
# En Railway con plan free usa: tiny
WHISPER_MODEL=tiny
